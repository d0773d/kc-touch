# Waveshare ESP32-P4 + 10.1-DSI-TOUCH-A defaults
CONFIG_KC_TOUCH_DISPLAY_ENABLE=y
CONFIG_KC_TOUCH_DISPLAY_BACKEND_WAVESHARE_P4=y
CONFIG_KC_TOUCH_DISPLAY_WIDTH=800
CONFIG_KC_TOUCH_DISPLAY_HEIGHT=1280
CONFIG_KC_TOUCH_TOUCH_ENABLE=y
CONFIG_KC_TOUCH_DISPLAY_ROTATION_0=y
CONFIG_BSP_LCD_TYPE_800_1280_10_1_INCH_A=y

# Waveshare JD9365 defaults
CONFIG_KC_TOUCH_WAVESHARE_LCD_RST_GPIO=27
CONFIG_KC_TOUCH_WAVESHARE_BACKLIGHT_GPIO=26
CONFIG_KC_TOUCH_WAVESHARE_MIPI_LDO_CHANNEL=3
CONFIG_KC_TOUCH_WAVESHARE_MIPI_LDO_MV=2500

# YamUI/LVGL defaults
CONFIG_SENSOR_MANAGER_ENABLE_FAKE_DATA=y
CONFIG_YAMUI_NAV_QUEUE_MAX_DEPTH=16
CONFIG_LV_USE_QRCODE=y
CONFIG_LV_BUILD_EXAMPLES=n
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_28=y
CONFIG_LV_FONT_MONTSERRAT_48=y
CONFIG_LV_USE_CLIB_MALLOC=y
CONFIG_LV_USE_CLIB_STRING=y
CONFIG_LV_USE_CLIB_SPRINTF=y
CONFIG_YUI_CAMERA_ENABLE=y
CONFIG_YUI_CAMERA_INTERFACE_MIPI_CSI=y
CONFIG_YUI_CAMERA_SCCB_I2C_PORT=0
CONFIG_YUI_CAMERA_SCCB_I2C_FREQ=10000
CONFIG_YUI_CAMERA_SCCB_SCL_PIN=8
CONFIG_YUI_CAMERA_SCCB_SDA_PIN=7
CONFIG_YUI_CAMERA_RESET_PIN=-1
CONFIG_YUI_CAMERA_PWDN_PIN=-1
CONFIG_YUI_CAMERA_MIPI_XCLK_PIN=-1
CONFIG_YUI_CAMERA_MIPI_XCLK_FREQ=24000000
CONFIG_CAMERA_OV5647=y
CONFIG_CAMERA_OV5647_MIPI_RAW10_1920X1080_30FPS=y
CONFIG_CAMERA_OV5647_MIPI_IF_FORMAT_INDEX_DEFAULT=0
CONFIG_CAMERA_OV5647_DEFAULT_IPA_JSON_CONFIGURATION_FILE=y

# Memory/partition settings for ESP32-P4 app footprint
CONFIG_IDF_EXPERIMENTAL_FEATURES=y
CONFIG_SPIRAM=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MEMTEST=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# Build profile
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_ESP_SYSTEM_USE_FRAME_POINTER=y
# CONFIG_ESP_SYSTEM_NO_BACKTRACE is not set
CONFIG_LV_FONT_DEJAVU_16_PERSIAN_HEBREW=y
CONFIG_LV_FONT_DEFAULT_DEJAVU_16_PERSIAN_HEBREW=y
