menu "KC Touch Display"

config KC_TOUCH_DISPLAY_ENABLE
    bool "Enable KC Touch display driver"
    default n
    help
        Enable the KC Touch display component used by the YamUI LVGL runtime.

if KC_TOUCH_DISPLAY_ENABLE

choice KC_TOUCH_DISPLAY_BACKEND
    prompt "Display backend"
    default KC_TOUCH_DISPLAY_BACKEND_WAVESHARE_P4
    help
        Select which board-specific display backend to compile.

config KC_TOUCH_DISPLAY_BACKEND_WAVESHARE_P4
    bool "Waveshare ESP32-P4 module dev kit (scaffold)"
    help
        Uses the Waveshare backend scaffold. Intended for ESP32-P4 targets.
        Panel/touch wiring still needs to be configured for your exact screen.

config KC_TOUCH_DISPLAY_BACKEND_TAB5
    bool "M5Stack Tab5"
    help
        Uses M5Unified/M5GFX based display and touch backend.

endchoice

config KC_TOUCH_DISPLAY_WIDTH
    int "Display width (pixels)"
    default 800 if KC_TOUCH_DISPLAY_BACKEND_WAVESHARE_P4
    default 720
    range 100 2000

config KC_TOUCH_DISPLAY_HEIGHT
    int "Display height (pixels)"
    default 1280 if KC_TOUCH_DISPLAY_BACKEND_WAVESHARE_P4
    default 1280
    range 100 2000

config KC_TOUCH_WAVESHARE_LCD_RST_GPIO
    int "Waveshare LCD reset GPIO"
    default 27
    range -1 48
    help
        GPIO used for JD9365 reset. Set to -1 if reset pin is not connected.

config KC_TOUCH_WAVESHARE_BACKLIGHT_GPIO
    int "Waveshare backlight GPIO"
    default 26
    range -1 48
    help
        GPIO used to control panel backlight. Set to -1 if handled elsewhere.

config KC_TOUCH_WAVESHARE_MIPI_LDO_CHANNEL
    int "Waveshare MIPI LDO channel"
    default 3
    range 0 7
    help
        LDO channel used to power MIPI DSI PHY.

config KC_TOUCH_WAVESHARE_MIPI_LDO_MV
    int "Waveshare MIPI LDO voltage (mV)"
    default 2500
    range 1800 3300
    help
        Voltage for the selected MIPI PHY LDO channel.

config KC_TOUCH_DISPLAY_BUFFER_LINES
    int "LVGL buffer height (lines)"
    default 40
    range 10 160

choice KC_TOUCH_DISPLAY_ROTATION
    prompt "Display rotation"
    default KC_TOUCH_DISPLAY_ROTATION_0

config KC_TOUCH_DISPLAY_ROTATION_0
    bool "0 degrees"
config KC_TOUCH_DISPLAY_ROTATION_90
    bool "90 degrees"
config KC_TOUCH_DISPLAY_ROTATION_180
    bool "180 degrees"
config KC_TOUCH_DISPLAY_ROTATION_270
    bool "270 degrees"
endchoice

config KC_TOUCH_TOUCH_ENABLE
    bool "Enable touch input"
    default y

endif # KC_TOUCH_DISPLAY_ENABLE

endmenu
